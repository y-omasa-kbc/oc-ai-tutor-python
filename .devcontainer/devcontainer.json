{
  "name": "oc-ai-tutor-python",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "mounts": [
    "source=oc-ai-tutor-python-venv,target=/workspace/.venv,type=volume"
  ],
  "containerUser": "vscode",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "editor.formatOnSave": false,
        "files.autoSave": "afterDelay"
      }
    }
  },
  "forwardPorts": [
    8501
  ],
  "portsAttributes": {
    "8501": {
      "label": "動作確認用 Web UI (Streamlit)",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python -m venv .venv && .venv/bin/pip install --no-cache-dir -r requirements.txt && .venv/bin/python -m app.data.index",
  "onCreateCommand": "mkdir -p .streamlit",
  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_BROWSER_GATHER_USAGE_STATS": "false"
  }
}
