{
  "name": "oc-ai-tutor-python",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "containerUser": "vscode",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": false,
        "files.autoSave": "afterDelay"
      }
    }
  },
  "forwardPorts": [
    8501,
    8502
  ],
  "portsAttributes": {
    "8501": {
      "label": "動作確認用 Web UI (Streamlit)",
      "onAutoForward": "openBrowser"
    },
    "8502": {
      "label": "実習用テキスト (HTTP サーバー)"
    }
  },
  "postCreateCommand": "bash /workspace/.devcontainer/postcreate.sh",
  "postStartCommand": "bash /workspace/.devcontainer/poststart.sh",
  "onCreateCommand": "mkdir -p .streamlit",
  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "STREAMLIT_SERVER_HEADLESS": "true",
    "STREAMLIT_BROWSER_GATHER_USAGE_STATS": "false"
  }
}
